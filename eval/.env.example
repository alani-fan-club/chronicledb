# OpenAI-compatible proxy for all LLM calls
NAVY_API_KEY=
NAVY_BASE_URL=https://api.openai.com/v1

# Models — pick whatever your proxy supports
STRONG_MODEL=claude-sonnet-4-5
MID_MODEL=gemini-2.5-pro
CHEAP_MODEL=gemma-3-27b-it

# Question generator + judge use the strong model by default
QGEN_MODEL=claude-sonnet-4-5
JUDGE_MODEL=claude-sonnet-4-5

# PostgreSQL connection (defaults to local)
PGHOST=localhost
PGPORT=5432
PGDATABASE=chronicledb
PGUSER=chronicledb
PGPASSWORD=

# Corpus configuration — point at your SillyTavern chat file
EVAL_CHAT_PATH=
EVAL_CHAT_ID=
EVAL_CHARACTER_NAME=
EVAL_USER_NAME=
